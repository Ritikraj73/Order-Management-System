{
  "info": {
    "name": "OMS - Order Management System",
    "description": "Complete API collection for the Distributed Order Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8081/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["auth", "register"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8081/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["auth", "register"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8081/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Product Service",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/products?page=0&size=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8082/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro 15\",\n  \"description\": \"High-performance laptop with 16GB RAM\",\n  \"price\": 1299.99,\n  \"category\": \"Electronics\"\n}"
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "http://localhost:8082/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products", "1"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro 15 - Updated\",\n  \"description\": \"Updated description\",\n  \"price\": 1399.99,\n  \"category\": \"Electronics\"\n}"
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "http://localhost:8082/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["products", "1"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Inventory Service",
      "item": [
        {
          "name": "Get Inventory",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8084/inventory/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["inventory", "1"]
            }
          }
        },
        {
          "name": "Add Stock",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8084/inventory/stock?productId=1&quantity=100",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["inventory", "stock"],
              "query": [
                {
                  "key": "productId",
                  "value": "1"
                },
                {
                  "key": "quantity",
                  "value": "100"
                }
              ]
            }
          }
        },
        {
          "name": "Reserve Stock",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8084/inventory/reserve",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["inventory", "reserve"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 5\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8083/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["orders"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"productId\": 2,\n      \"quantity\": 1\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get User Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["orders"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/orders/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["orders", "1"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": ""
    }
  ]
}